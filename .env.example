# ============================================================================
# WorkFlow Pro QA Automation Framework - Environment Configuration Template
# ============================================================================
# Copy this file to .env and update with your configuration
# WARNING: Never commit .env file with actual secrets to version control
# ============================================================================

# ============================================================================
# REQUIRED BY conftest.py
# ============================================================================

ENVIRONMENT=qa

QA_BASE_URL=https://app.workflowpro.com
QA_API_BASE_URL=https://api.workflowpro.com

QA_TENANT_ID=company1
QA_TENANT_NAME=Company One

QA_USERNAME=admin@company1.com
QA_PASSWORD=password123

DEFAULT_TIMEOUT_MS=30000

USE_BROWSERSTACK=false

HEADLESS=true

BROWSER=chromium

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
QA_BASE_URL=https://app.workflowpro.com
APP_BASE_URL=https://app.workflowpro.com
APP_LOGIN_URL=https://app.workflowpro.com/login
APP_DASHBOARD_URL=https://app.workflowpro.com/dashboard
QA_API_BASE_URL=https://api.workflowpro.com
APP_API_BASE_URL=https://api.workflowpro.com

# ============================================================================
# TEST ACCOUNTS (Multi-tenant Setup)
# ============================================================================
# Company 1 - Admin Account
QA_USERNAME=admin@company1.com
ADMIN_EMAIL=admin@company1.com
QA_PASSWORD=password123
ADMIN_PASSWORD=secure_password_here

# Company 1 - Regular User
COMPANY1_USER_EMAIL=user@company1.com
COMPANY1_USER_PASSWORD=secure_password_here

# Company 2 - Regular User (for tenant isolation tests)
COMPANY2_USER_EMAIL=user@company2.com
COMPANY2_USER_PASSWORD=secure_password_here

# Test user with 2FA enabled (for 2FA testing)
2FA_ENABLED_USER_EMAIL=2fa@company1.com
2FA_ENABLED_USER_PASSWORD=secure_password_here

# ============================================================================
# API CONFIGURATION
# ============================================================================
API_TOKEN=your_bearer_token_here
X_TENANT_ID=company1
API_REQUEST_TIMEOUT=30
API_MAX_RETRIES=3

# ============================================================================
# BROWSER CONFIGURATION
# ============================================================================
# Options: chromium, firefox, webkit
BROWSER=chromium

# Headless mode: true or false
HEADLESS=true

# Browser window size
BROWSER_WIDTH=1920
BROWSER_HEIGHT=1080

# Mobile device emulation (leave empty for desktop)
# Examples: "iPhone 12", "Pixel 5", "iPad Pro"
MOBILE_DEVICE=

# Slow motion (milliseconds to add between actions)
SLOW_MO=0

# ============================================================================
# BROWSERSTACK CONFIGURATION
# ============================================================================
# Set to true to enable BrowserStack testing
BROWSERSTACK_ENABLED=false
BROWSERSTACK_USERNAME=your_browserstack_username
BROWSERSTACK_ACCESS_KEY=your_browserstack_access_key
BROWSERSTACK_LOCAL_ENABLED=false
BROWSERSTACK_LOCAL_IDENTIFIER=

# BrowserStack browser options
BS_BROWSER=Chrome
BS_BROWSER_VERSION=latest
BS_OS=Windows
BS_OS_VERSION=11
BS_RESOLUTION=1920x1080
BS_BUILD_NAME=WorkFlowPro-QA-Build
BS_PROJECT_NAME=WorkFlowPro-Automation

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file location
LOG_FILE=reports/logs/automation.log

# ============================================================================
# SCREENSHOT & ARTIFACT CONFIGURATION
# ============================================================================
# Take screenshot on test failure
SCREENSHOT_ON_FAILURE=true

# Screenshot directory
SCREENSHOT_DIR=reports/screenshots

# Save Playwright trace files on failure
TRACE_ON_FAILURE=true

# Trace file directory
TRACE_DIR=reports/traces

# Video recording on test failure
VIDEO_ON_FAILURE=false

# Video directory
VIDEO_DIR=reports/videos

# ============================================================================
# WAIT & TIMEOUT CONFIGURATION
# ============================================================================
# Default wait timeout in seconds
DEFAULT_TIMEOUT=10

# Explicit wait timeout in seconds
EXPLICIT_WAIT_TIMEOUT=15

# Page load timeout in seconds
PAGE_LOAD_TIMEOUT=30

# Dynamic element loading timeout
DYNAMIC_ELEMENT_TIMEOUT=20

# 2FA code wait timeout
TWO_FA_TIMEOUT=60

# ============================================================================
# RETRY CONFIGURATION
# ============================================================================
# Maximum number of test retries on failure
MAX_TEST_RETRIES=1

# Retry delay in seconds
RETRY_DELAY=2

# ============================================================================
# TEST DATA CONFIGURATION
# ============================================================================
# Test data cleanup after test execution
CLEANUP_TEST_DATA=true

# Delete test projects after test completion
DELETE_TEST_PROJECTS=true

# ============================================================================
# ENVIRONMENT SELECTION
# ============================================================================
# Options: local, staging, production (production for API tests only)
TEST_ENVIRONMENT=staging

# ============================================================================
# PARALLEL EXECUTION
# ============================================================================
# Number of parallel workers (0 = disable parallel execution)
PARALLEL_WORKERS=0

# ============================================================================
# REPORTING CONFIGURATION
# ============================================================================
# Generate HTML report
GENERATE_HTML_REPORT=true

# Generate Allure report
GENERATE_ALLURE_REPORT=true

# Report directory
REPORT_DIR=reports

# ============================================================================
# CI/CD CONFIGURATION
# ============================================================================
# Running in CI environment (GitHub Actions, Jenkins, etc.)
CI_ENVIRONMENT=false

# CI Provider: github, jenkins, gitlab, azure
CI_PROVIDER=

# ============================================================================
# DEBUG & DEVELOPMENT
# ============================================================================
# Enable debug mode (additional logging and tracing)
DEBUG_MODE=false

# Pause on test failure for debugging
PAUSE_ON_FAILURE=false

# ============================================================================
END OF CONFIGURATION
# ============================================================================
